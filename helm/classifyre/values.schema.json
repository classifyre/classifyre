{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Classifyre Helm values schema",
  "type": "object",
  "properties": {
    "api": {
      "type": "object",
      "properties": {
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
            }
          }
        },
        "cliJobs": {
          "type": "object",
          "properties": {
            "cleanupPolicy": {
              "type": "string",
              "enum": ["none", "failed", "always"]
            },
            "huggingFace": {
              "type": "object",
              "properties": {
                "existingSecret": {
                  "type": "string"
                },
                "existingKey": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "maskedConfigEncryption": {
          "type": "object",
          "properties": {
            "existingSecret": {
              "type": "string"
            },
            "secretName": {
              "type": "string"
            },
            "secretKey": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "string"
            },
            "autoGenerate": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "frontend": {
      "type": "object",
      "properties": {
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
            }
          }
        }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["external", "cnpg", "embedded"]
        },
        "connection": {
          "type": "object",
          "properties": {
            "sslMode": {
              "type": "string",
              "enum": ["disable", "require", "verify-ca", "verify-full"]
            }
          }
        }
      }
    },
    "objectStorage": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "bucket": { "type": "string" },
        "logPrefix": { "type": "string" },
        "region": { "type": "string" },
        "endpoint": { "type": "string" },
        "forcePathStyle": { "type": "boolean" },
        "accessKeyId": { "type": "string" },
        "secretAccessKey": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretAccessKeyIdKey": { "type": "string" },
        "existingSecretSecretAccessKeyKey": { "type": "string" }
      }
    }
  }
}
