  OPEN
  FALSE_POSITIVE
  RESOLVED
  IGNORED
}

enum AssetStatus {
  NEW
  UPDATED
  UNCHANGED
  DELETED
}

enum RunnerAssetStatus {
  PENDING
  PROCESSING
  PROCESSED
  ERROR
}

