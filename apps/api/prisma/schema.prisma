  CONFLUENCE
  CROWD
  BITBUCKET
  SERVICEDESK
  XRAY
  GOOGLE_DRIVE
  GOOGLE_SHEETS
  GOOGLE_DOCS
  GOOGLE_SLIDES
  WORDPRESS
  SLACK
  S3_COMPATIBLE_STORAGE
  AZURE_BLOB_STORAGE
  GOOGLE_CLOUD_STORAGE
  POSTGRESQL
  MYSQL
  MSSQL
  ORACLE
  HIVE
  DATABRICKS
  SNOWFLAKE
  MONGODB
  NEO4J
  SQLITE
  NOTION
  POWERBI
  TABLEAU
  EMAIL
  YOUTUBE
  DELTA_LAKE
  ICEBERG
  KAFKA
  ELASTICSEARCH
  OPENSEARCH
  MEILISEARCH
  CUSTOM
}

enum RunnerStatus {
  PENDING
  RUNNING
  COMPLETED
  WARNING
  ERROR
}

enum RunnerExecutionMode {
  LOCAL
  KUBERNETES
  EXTERNAL
}

enum TriggerType {
  MANUAL
  SCHEDULED
  WEBHOOK
  API
  // The investigation autopilot re-scanned a source to verify a detection
  // change it just made. Tagged so the resulting cycle never re-scans again.
  AUTOPILOT
}

enum NotificationType {
  SCAN
  FINDING
  SOURCE
  SYSTEM
}

enum InstanceLanguage {
  AUTOMATIC
  ENGLISH
  GERMAN
}

enum InstanceTimeFormat {
  AUTOMATIC
  TWELVE_HOUR
  TWENTY_FOUR_HOUR
}

enum DetectorType {
  SECRETS
  PII
  YARA
  BROKEN_LINKS
  CODE_SECURITY
  CUSTOM
}

enum CustomDetectorTrainingStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum TestResultStatus {
  PASS
  FAIL
  ERROR
}

enum TestTrigger {
  MANUAL
  CI
  ASSISTANT
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  OPEN
  FALSE_POSITIVE
  RESOLVED
  IGNORED
}

enum AssetStatus {
  NEW
  UPDATED
  UNCHANGED
  DELETED
}

enum RunnerAssetStatus {
  PENDING
  PROCESSING
  PROCESSED
  ERROR
}

enum AssetContentType {
  TXT
  TABLE
  IMAGE
  VIDEO
  AUDIO
  URL
  BINARY
  OTHER
}

enum SandboxRunStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
}

model SandboxRun {
  id            String           @id @default(uuid())
  createdAt     DateTime         @default(now()) @map("created_at")
  fileName      String           @map("file_name")
  fileType      String           @map("file_type")
  contentType   AssetContentType @default(OTHER) @map("content_type")
  fileExtension String           @map("file_extension")
  fileSizeBytes Int              @map("file_size_bytes")
  detectors     Json             @db.JsonB
  findings      Json             @default("[]") @db.JsonB
  status        SandboxRunStatus @default(PENDING)
  errorMessage  String?          @map("error_message")
  durationMs    Int?             @map("duration_ms")
  // S3-backed file storage: key in the sandbox bucket and SHA-256 content hash
  s3Key         String?          @map("s3_key")
  contentHash   String?          @map("content_hash")
  // Transient file bytes for K8s job transport: the input file is stored here
  // only while a K8s sandbox job runs, served to the job's init-container over
  // the cluster network, then cleared. Never uses S3 for the sandbox.
  inputData     Bytes?           @map("input_data")

  @@index([status])
  @@index([createdAt])
  @@index([contentHash])
  @@map("sandbox_runs")
}


// ─── INVESTIGATIONS (CASES / GRAPH) ──────────────────────────────

enum EdgeOrigin {
  SOURCE_DERIVED
  INFERRED
  MANUAL
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum HypothesisStatus {
  PROPOSED
  SUPPORTED
  REFUTED
  INCONCLUSIVE
}

enum CaseThreadKind {
  HYPOTHESIS
  DISCUSSION
}

enum CaseThreadEntryType {
  NOTE
  STATEMENT
  STATUS_CHANGE
  CONFIDENCE_CHANGE
}

enum CaseActivityType {
  CASE_CREATED
  CASE_UPDATED
  CONCLUSION_UPDATED
  INQUIRY_LINKED
  INQUIRY_UNLINKED
  INQUIRY_PULLED
  EVIDENCE_ADDED
  EVIDENCE_REMOVED
  EVIDENCE_NOTE_UPDATED
  FINDING_ADDED
  FINDING_REMOVED
  FINDING_NOTE_UPDATED
  THREAD_CREATED
  THREAD_ENTRY_ADDED
  THREAD_STATEMENT_UPDATED
  THREAD_STATUS_CHANGED
  THREAD_CONFIDENCE_CHANGED
  SUPPORT_LINKED
  SUPPORT_UNLINKED
  SUPPORT_UPDATED
}

enum EvidenceStance {
  SUPPORTS
  CONTRADICTS
  NEUTRAL
}

// Generic, directed relationship between any two graph entities.
// `fromType`/`toType` are entity kinds ("asset" | "finding", room for
// "concept" later) and the ids reference the corresponding rows. The
// relation type is a free-form string so the inference engine (and a
// future ingestion path) can introduce new kinds without a migration.
model Edge {
  id           String     @id @default(uuid())
  fromType     String     @map("from_type")
  fromId       String     @map("from_id")
  toType       String     @map("to_type")
  toId         String     @map("to_id")
  relationType String     @map("relation_type")
  confidence   Decimal    @default(1.00) @db.Decimal(3, 2)
  origin       EdgeOrigin @default(INFERRED)
  metadata     Json?      @db.JsonB
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([fromType, fromId, toType, toId, relationType])
  @@index([fromType, fromId])
  @@index([toType, toId])
  @@index([relationType])
  @@map("edges")
}

// ─── ASSET CORRELATION / DUPLICATE DETECTION ─────────────────────────────
//
// Deterministic "evidence fingerprints" derived from findings. No embeddings:
// each finding's normalized value becomes a correlatable token; the reverse
// index (value_hash → assets) keeps candidate lookups cheap, and weighted +
// Jaccard overlap produces explainable similarity. See apps/api/src/correlation.

// One normalized, correlatable finding value attached to an asset. This is the
// reverse index: querying by `valueHash` yields every asset sharing a value.
// `label` is the finding's free-form type (email, phone, custom labels, …) so
// correlation stays label-agnostic.
model AssetCorrelationValue {
  id                String       @id @default(uuid())
  assetId           String       @map("asset_id")
  sourceId          String       @map("source_id")
  label             String
  detectorType      DetectorType @map("detector_type")
  customDetectorKey String?      @map("custom_detector_key")
  normalizedValue   String       @map("normalized_value") @db.Text
  // sha256(label + ':' + normalizedValue) — the reverse-index key.
  valueHash         String       @map("value_hash") @db.VarChar(64)
  // sha256 of sorted DoubleMetaphone codes for each token in the value.
  // Non-null only for text-like labels (person, name, address, …) where
  // phonetic similarity is meaningful. Used as a second blocking key so
  // "John Smith" and "Jon Smyth" end up as correlation candidates.
  phoneticHash      String?      @map("phonetic_hash") @db.VarChar(64)
  createdAt         DateTime     @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, valueHash])
  @@index([valueHash])
  @@index([assetId])
  @@index([sourceId])
  @@index([label, phoneticHash])
  @@map("asset_correlation_values")
}

// Per-asset signature: component hashes (one per label) for fast same-category
// matching plus an all-values hash that buckets exact duplicates.
model AssetSignature {
  assetId         String   @id @map("asset_id")
  sourceId        String   @map("source_id")
  // { "email": "<hash>", "phone": "<hash>", ... } — hash of sorted values per label.
  componentHashes Json     @map("component_hashes") @db.JsonB
  allValuesHash   String   @map("all_values_hash") @db.VarChar(64)
  valueCount      Int      @map("value_count")
  updatedAt       DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([allValuesHash])
  @@index([sourceId])
  @@map("asset_signatures")
}

// An identity cluster: a connected group of assets that share enough strong
// evidence to be treated as the same entity. Members are maintained by the
// duplicates finder via union-find over likely-duplicate edges.
model AssetCluster {
  id          String   @id @default(uuid())
  label       String?
  memberCount Int      @default(0) @map("member_count")
  sourceCount Int      @default(0) @map("source_count")
  // Common findings across members, e.g. [{ label, value, count }] — for the UI.
  topValues   Json?    @map("top_values") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members AssetClusterMember[]

  @@index([memberCount])
  @@map("asset_clusters")
}

model AssetClusterMember {
  clusterId String   @map("cluster_id")
  assetId   String   @map("asset_id")
  addedAt   DateTime @default(now()) @map("added_at")

  cluster AssetCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  asset   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([clusterId, assetId])
  // An asset belongs to at most one cluster.
  @@unique([assetId])
  @@index([clusterId])
  @@map("asset_cluster_members")
}

// Singleton tuning for the correlation engine. Weights are keyed by the
// (normalized) finding label and are fully dynamic — any label, including
// custom-detector ones, can be given a weight; unlisted labels fall back to
// defaultWeight. Editing this triggers a full recompute (logged as a
// DUPLICATES FINDER run). Defaults mirror correlation.constants.ts.
model CorrelationConfig {
  id            Int      @id @default(1)
  labelWeights  Json     @default("{}") @map("label_weights") @db.JsonB
  defaultWeight Int      @default(1) @map("default_weight")
  relatedMin    Decimal  @default(0.30) @map("related_min") @db.Decimal(3, 2)
  duplicateMin  Decimal  @default(0.60) @map("duplicate_min") @db.Decimal(3, 2)
  // Values to ignore when fingerprinting (noise like Person "null"). Array of
  // { id, mode: "value"|"regex"|"label", label, value }. Applied at indexing
  // time; editing triggers a full recompute.
  exclusions    Json     @default("[]") @map("exclusions") @db.JsonB
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("correlation_config")
}

// Scratch space for a recompute pass: the pairwise overlap aggregation
// (GROUP BY over the asset_correlation_values self-join) runs as a single
// INSERT ... SELECT so the heavy intermediate state lives in Postgres
// (work_mem / on-disk temp files), never in the API process's heap. Rows are
// scoped by run_id and deleted once that run's edges have been written.
model CorrelationPairStaging {
  id            BigInt  @id @default(autoincrement())
  runId         String  @map("run_id")
  aId           String  @map("a_id")
  bId           String  @map("b_id")
  sharedCount   Int     @map("shared_count")
  weightedShared Decimal @map("weighted_shared") @db.Decimal(12, 4)
  sharedByLabel Json    @map("shared_by_label") @db.JsonB

  @@index([runId, id])
  @@map("correlation_pair_staging")
}

enum InquiryStatus {
  ACTIVE
  ARCHIVED
}

// The investigation. A case owns hypotheses and the real, persisted evidence. It
// may link one or more questions (saved queries) that guide which findings are
// relevant; evidence is pulled from those queries' matches or added manually.
model Case {
  id          String     @id @default(uuid())
  title       String
  description String?    @db.Text
  status      CaseStatus @default(OPEN)
  severity    Severity   @default(MEDIUM)
  assignee    String?
  createdBy   String?    @map("created_by")
  aiMode      AiManagementMode @default(INHERIT) @map("ai_mode")
  conclusion  String?    @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  evidence     CaseEvidence[]
  findings     CaseFinding[]
  notes        CaseNote[]
  inquiryLinks CaseInquiry[]
  threads      CaseThread[]
  activities   CaseActivity[]

  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("cases")
}

// A saved query / monitor. It does NOT persist evidence — it only defines matchers
// and tracks which findings currently match (QuestionMatch) so we can surface new
// matches. An inquiry is standalone or linked to any number of cases (CaseInquiry).
//
// Matchers: a finding matches iff source matches AND (detector OR customDetector
// matches) AND type matches, where an empty list for a dimension means "any".
// findingTypeRegex is evaluated in the app (findingType is dynamic for CUSTOM).
model Inquiry {
  id          String         @id @default(uuid())
  title       String
  description String?        @db.Text
  status      InquiryStatus @default(ACTIVE)
  createdBy   String?        @map("created_by")
  aiMode      AiManagementMode @default(INHERIT) @map("ai_mode")

  matchAllSources    Boolean        @default(false) @map("match_all_sources")
  sourceIds          String[]       @map("source_ids")
  detectorTypes      DetectorType[] @map("detector_types")
  customDetectorKeys String[]       @map("custom_detector_keys")
  findingTypes       String[]       @map("finding_types")
  findingTypeRegex   String[]       @map("finding_type_regex")
  findingValueRegex  String[]       @map("finding_value_regex")

  matchCount    Int       @default(0) @map("match_count")
  newMatchCount Int       @default(0) @map("new_match_count")
  matchesSeenAt DateTime? @map("matches_seen_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  caseLinks CaseInquiry[]

  @@index([status])
  @@map("inquiries")
}

// Many-to-many link: an inquiry can guide several cases and a case can be
// driven by several inquiries. Deleting either side removes only the link.
model CaseInquiry {
  id        String   @id @default(uuid())
  caseId    String   @map("case_id")
  inquiryId String   @map("inquiry_id")
  createdAt DateTime @default(now()) @map("created_at")

  case    Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@unique([caseId, inquiryId])
  @@index([inquiryId])
  @@map("case_inquiries")
}

// An observed node attached to a CASE. entityType: "asset" | "sandbox". Display
// fields are denormalized snapshots so the node survives source-row deletion.
model CaseEvidence {
  id         String   @id @default(uuid())
  caseId     String   @map("case_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  label      String?
  assetType  String?  @map("asset_type")
  sourceType String?  @map("source_type")
  note       String?  @db.Text
  addedBy    String?  @map("added_by")
  createdAt  DateTime @default(now()) @map("created_at")

  investigation Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  findings      CaseFinding[]

  @@unique([caseId, entityType, entityId])
  @@index([caseId])
  @@index([entityType, entityId])
  @@map("case_evidence")
}

// Inferred observation anchored to case evidence. No FK to findings; findingId is a
// plain reference. Denormalized snapshots survive deletion of the finding row.
model CaseFinding {
  id             String   @id @default(uuid())
  caseId         String   @map("case_id")
  caseEvidenceId String   @map("case_evidence_id")
  findingId      String   @map("finding_id")
  label          String
  severity       String?
  detectorType         String?  @map("detector_type")
  customDetectorName   String?  @map("custom_detector_name")
  matchedContent       String?  @map("matched_content") @db.Text
  note                 String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  investigation Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseEvidence  CaseEvidence @relation(fields: [caseEvidenceId], references: [id], onDelete: Cascade)

  @@unique([caseId, findingId])
  @@index([caseId])
  @@index([caseEvidenceId])
  @@map("case_findings")
}


model CaseNote {
  id        String   @id @default(uuid())
  caseId    String   @map("case_id")
  body      String   @db.Text
  author    String?
  createdAt DateTime @default(now()) @map("created_at")

  investigation Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_notes")
}

// Thread container: hypothesis thread (replaces Hypothesis) or custom discussion thread.
model CaseThread {
  id         String          @id @default(uuid())
  caseId     String          @map("case_id")
  kind       CaseThreadKind  @default(HYPOTHESIS)
  title      String
  // Hypothesis-only denormalized current state (for graph/quick queries)
  status     HypothesisStatus? @default(PROPOSED)
  confidence Decimal?         @db.Decimal(3, 2)
  color      String?
  createdBy  String?          @map("created_by")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  investigation Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  entries       CaseThreadEntry[]
  support       CaseThreadSupport[]

  @@index([caseId])
  @@index([caseId, kind])
  @@map("case_threads")
}

// Append-only evolution log for a thread (notes, statement revisions, status changes).
model CaseThreadEntry {
  id        String              @id @default(uuid())
  threadId  String              @map("thread_id")
  entryType CaseThreadEntryType @default(NOTE) @map("entry_type")
  body      String?             @db.Text
  metadata  Json?               @db.JsonB
  author    String?
  createdAt DateTime            @default(now()) @map("created_at")

  thread  CaseThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  support CaseThreadSupport[]

  @@index([threadId, createdAt])
  @@map("case_thread_entries")
}

// Polymorphic link between a thread (and optionally an entry) and evidence/finding.
model CaseThreadSupport {
  id         String         @id @default(uuid())
  threadId   String         @map("thread_id")
  entryId    String?        @map("entry_id")
  targetType String         @map("target_type")
  targetId   String         @map("target_id")
  stance     EvidenceStance @default(SUPPORTS)
  weight     Decimal?       @db.Decimal(3, 2)
  note       String?        @db.Text
  createdAt  DateTime       @default(now()) @map("created_at")

  thread CaseThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  entry  CaseThreadEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@unique([threadId, targetType, targetId])
  @@index([threadId])
  @@index([targetType, targetId])
  @@map("case_thread_support")
}

// Append-only case event log — the unified timeline.
model CaseActivity {
  id           String          @id @default(uuid())
  caseId       String          @map("case_id")
  activityType CaseActivityType @map("activity_type")
  actor        String?
  payload      Json?           @db.JsonB
  createdAt    DateTime        @default(now()) @map("created_at")

  investigation Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt(sort: Desc)])
  @@map("case_activities")
}

// ── Investigation autopilot ──────────────────────────────────────────────────
// Autonomous background agents that manage inquiries and cases after scans.
// Every cycle is an AgentRun; every (non-)action is an AgentDecision with a
// mandatory rationale; learned domain knowledge lives in AgentMemory.

// Per-entity override of the instance-wide autopilot flags. OBSERVE_ONLY means
// the agent may read the entity but never mutate it.
enum AiManagementMode {
  INHERIT
  MANAGED
  OBSERVE_ONLY
}

enum AgentKind {
  INQUIRY
  CASE
  // Periodic "dreaming": memory consolidation — dedupe, prune noise, distill
  // important lessons. No inquiry/case mutations.
  DREAM
  // Deterministic asset-correlation step (no LLM). Runs after a scan, before
  // the inquiry/case agents, and records its work in the autopilot log so the
  // results are visible and the AI agents can take them into account.
  DUPLICATES
  // Config-tuning agent: investigates sources by changing editable config
  // (detectors, sampling, optional, resources) — never base connection.
  CONFIG
  // Detector-authoring agent: creates/trains custom detectors when needed.
  DETECTOR_AUTHOR
  // Alerting/escalation agent: reviews open cases and notifies an operator when
  // a high-severity case appears, so the harness can run unattended. Mutates
  // nothing in the investigation graph — it only raises operator notifications.
  ESCALATION
  // Conversational chat-gateway turn (Telegram/Slack bot). Never enqueued by
  // the autopilot pipeline; one run per inbound chat message for usage/audit.
  CHAT
}

enum AgentRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  // Stopped by the operator; the runtime aborts before the next step.
  CANCELLED
}

enum AgentDecisionAction {
  CREATE_INQUIRY
  UPDATE_INQUIRY
  ENRICH_INQUIRY_MATCHERS
  SIGNAL_CASE_READY
  CREATE_CASE
  UPDATE_CASE
  ADD_HYPOTHESIS
  UPDATE_HYPOTHESIS
  ADD_EVIDENCE
  ATTACH_FINDINGS
  ADD_NOTE
  ADD_THREAD_ENTRY
  CREATE_EDGE
  // Disconnect a manual edge the data no longer supports (focused case runs).
  REMOVE_EDGE
  // Link evidence/findings to a hypothesis thread (supports/contradicts).
  LINK_SUPPORT
  CHANGE_STATUS
  LINK_INQUIRY
  // Dream-mode memory maintenance (prune / rewrite / merge).
  CONSOLIDATE_MEMORY
  // Duplicates finder: a pairwise asset-correlation link was created/updated.
  LINK_DUPLICATE
  // Duplicates finder: an identity cluster was created/grown/merged.
  UPDATE_CLUSTER
  // Harness: a generic tool was invoked by the agent loop (read or mutate).
  TOOL_CALL
  // Config-tuning agent: a source's editable config was changed.
  TUNE_SOURCE
  // Detector-authoring agent: a custom detector was created.
  CREATE_DETECTOR
  // Detector-authoring agent: a custom detector was trained.
  TRAIN_DETECTOR
  // Detector-authoring agent: a custom detector was updated (config/active flag).
  UPDATE_DETECTOR
  // Detector-authoring agent: a custom detector was deleted.
  DELETE_DETECTOR
  // Config-tuning agent: a source scan was triggered.
  TRIGGER_SCAN
  // Harness: the living system brief was updated.
  UPDATE_SYSTEM_BRIEF
  // Fingerprints: recomputed asset correlation/similarity on demand.
  RECOMPUTE_CORRELATION
  // Fingerprints: tuned correlation config (weights/exclusions/thresholds).
  TUNE_CORRELATION
  // Escalation agent: raised an operator notification about a high-severity case.
  NOTIFY_OPERATOR
  NO_ACTION
}

enum AgentDecisionOutcome {
  APPLIED
  SKIPPED_OBSERVE_ONLY
  FAILED
}

enum AgentMemoryKind {
  GLOSSARY
  DECISION_PRECEDENT
  // Topic → any entity (inquiry/case/source/detector) mapping for dedupe.
  ENTITY_MAP
  // Per-source learned facts: typical finding mix, false-positive patterns,
  // detector/sampling settings that worked well.
  SOURCE_PROFILE
  // What a detector catches/misses and tuning lessons.
  DETECTOR_INSIGHT
  // Sacred operator corrections/opt-outs — never pruned by the dream agent.
  OPERATOR_DIRECTIVE
}

// An external MCP server the harness can connect to and call tools from.
// Credentials (headers) are encrypted at rest. agentKinds scopes which missions
// may use the server's tools (empty = all). Untrusted servers expose their tools
// observe-only (the dispatcher refuses to run their mutating handlers).
model McpServerConfig {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  transport       String // "stdio" | "http"
  command         String?
  args            String[]  @default([])
  url             String?
  headersEnc      String?   @map("headers_enc")
  enabled         Boolean   @default(false)
  trusted         Boolean   @default(false)
  // Mission kinds allowed to use these tools (AgentKind strings). Empty = all.
  agentKinds      String[]  @default([]) @map("agent_kinds")
  // Discovered tool names to expose. Empty = all discovered.
  toolAllowlist   String[]  @default([]) @map("tool_allowlist")
  // Last connection result for the UI.
  discoveredTools String[]  @default([]) @map("discovered_tools")
  lastError       String?   @map("last_error") @db.Text
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("mcp_server_configs")
}

// Per-agent harness configuration. One optional row per AgentKind that has a
// factory mission (see harness/missions.ts). Absent columns fall back to the
// hardcoded factory default, so an absent row means "fully default". The
// operator edits these via the Harness → Agents UI to retune an agent's goal,
// iteration budget and assigned built-in tools without a code change.
model AgentConfig {
  kind          AgentKind @id
  // Override for the mission goal (system prompt). null = factory default.
  goal          String?   @db.Text
  // Override for the iteration budget. null = factory default.
  maxIterations Int?      @map("max_iterations")
  // Assigned built-in tool names (used only when toolsOverride is true).
  toolNames     String[]  @default([]) @map("tool_names")
  // false = follow the factory toolset; true = use toolNames verbatim. Lets an
  // empty assignment ("no tools") differ from "never customised".
  toolsOverride Boolean   @default(false) @map("tools_override")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("agent_configs")
}

// Living, always-injected summary of the whole system the autopilot maintains:
// source/detector counts, finding landscape, what's been tried, known gaps.
// Singleton (id = 1), like InstanceSettings. The narrative is model-authored;
// `facts` holds structured aggregates refreshed from the search service.
model AgentSystemBrief {
  id        Int      @id @default(1)
  content   String   @default("") @db.Text
  facts     Json     @default("{}") @db.JsonB
  version   Int      @default(1)
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agent_system_brief")
}

// One autonomous agent cycle (triggered by a scan completion). currentStep +
// stepState make the pipeline resumable across pg-boss redeliveries without
// repeating LLM calls whose validated output is already stored.
model AgentRun {
  id          String         @id @default(uuid())
  agentKind   AgentKind      @map("agent_kind")
  status      AgentRunStatus @default(PENDING)
  sourceId    String?        @map("source_id")
  runnerId    String?        @map("runner_id")
  // Case this run is focused on (case-targeted manual runs) — lets the case
  // workspace show "AI is working here" and surface the results.
  caseId      String?        @map("case_id")
  trigger     String         @default("scan_completed")
  // Operator instruction for manually triggered cycles ("steer" runs).
  instruction String?        @db.Text
  // Stable identity of the cycle that produced this run — used to resume the
  // right run on pg-boss redelivery (scan: source:runner, manual: uuid).
  cycleKey    String?        @map("cycle_key")
  currentStep String?        @map("current_step")
  stepState   Json?          @db.JsonB @map("step_state")
  attempts    Int            @default(0)
  error       String?        @db.Text
  summary     String?        @db.Text
  // LLM token consumption of this run (all iterations/attempts summed) and the
  // estimated cost derived from the provider's configured per-MTok prices at
  // the time the tokens were recorded. costUsd stays null when no pricing set.
  inputTokens  Int           @default(0) @map("input_tokens")
  outputTokens Int           @default(0) @map("output_tokens")
  costUsd      Decimal?      @map("cost_usd") @db.Decimal(14, 6)
  startedAt   DateTime?      @map("started_at")
  finishedAt  DateTime?      @map("finished_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  decisions AgentDecision[]
  logs      AgentLog[]

  @@index([agentKind, createdAt(sort: Desc)])
  @@index([status])
  @@index([cycleKey])
  @@index([caseId, createdAt(sort: Desc)])
  @@map("agent_runs")
}

enum AgentLogChannel {
  // Internal mechanics: step transitions, prompts/raw model output, retries.
  TECHNICAL
  // Human-readable narrative of what the agent observed and did.
  BUSINESS
}

enum AgentLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// Append-only execution log of a run. BUSINESS entries tell the analyst the
// story; TECHNICAL entries carry raw model I/O and step mechanics (including
// the raw responses behind schema failures).
model AgentLog {
  id        String          @id @default(uuid())
  runId     String          @map("run_id")
  channel   AgentLogChannel
  level     AgentLogLevel   @default(INFO)
  message   String          @db.Text
  payload   Json?           @db.JsonB
  createdAt DateTime        @default(now()) @map("created_at")

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([runId, channel])
  @@map("agent_logs")
}

// A single agent decision — including the decision to do nothing. Rationale is
// always required; payload holds the exact mutation input for auditability.
model AgentDecision {
  id         String               @id @default(uuid())
  runId      String               @map("run_id")
  action     AgentDecisionAction
  outcome    AgentDecisionOutcome @default(APPLIED)
  entityType String?              @map("entity_type")
  entityId   String?              @map("entity_id")
  rationale  String               @db.Text
  payload    Json?                @db.JsonB
  createdAt  DateTime             @default(now()) @map("created_at")

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([entityType, entityId])
  @@index([action, createdAt(sort: Desc)])
  @@map("agent_decisions")
}

// Long-lived agent knowledge: domain glossary, generalized decision precedents
// and topic→inquiry mappings. Recalled via pg_trgm similarity on key/content
// (raw SQL indexes in the migration). weight is a reinforcement counter.
model AgentMemory {
  id        String          @id @default(uuid())
  kind      AgentMemoryKind
  key       String
  content   String          @db.Text
  tags      String[]        @default([])
  refType   String?         @map("ref_type")
  refId     String?         @map("ref_id")
  weight    Int             @default(1)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([kind, key])
  @@index([kind])
  @@index([tags], type: Gin)
  @@map("agent_memories")
}

// ── Chat gateway (Telegram / Slack bots) ─────────────────────────────────────
// Conversational interface into the AI harness: each configured bot connects
// via long-polling (Telegram) or Socket Mode (Slack), and every chat turn runs
// the chat agent loop with the built-in MCP toolset (AgentRun kind CHAT).

enum ChatPlatform {
  TELEGRAM
  SLACK
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

model ChatBot {
  id       String       @id @default(uuid())
  platform ChatPlatform
  name     String
  enabled  Boolean      @default(false)
  // Bot credentials, AES-GCM encrypted (MaskedConfigCryptoService).
  botTokenEnc String  @map("bot_token_enc")
  // Slack Socket Mode app-level token (xapp-…); unused for Telegram.
  appTokenEnc String? @map("app_token_enc")
  // MCP capability group ids the bot may use (mcp-catalog.ts); empty = all.
  capabilityGroups String[] @default([]) @map("capability_groups")
  // AgentKinds the bot may steer via autopilot tools; empty = all.
  agentKinds String[] @default([]) @map("agent_kinds")
  // When false every mutating tool resolves OBSERVE_ONLY (read-only bot).
  allowMutations Boolean @default(true) @map("allow_mutations")
  // Connector status, mirrored by ChatGatewayService.
  lastError       String?   @db.Text @map("last_error")
  lastConnectedAt DateTime? @map("last_connected_at")
  // Telegram getUpdates offset — survives restarts without replaying messages.
  telegramLastUpdateId BigInt?  @map("telegram_last_update_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  sessions ChatSession[]

  @@map("chat_bots")
}

model ChatSession {
  id    String @id @default(uuid())
  botId String @map("bot_id")
  // Platform conversation identity: Telegram chat id, Slack "channel:thread_ts".
  externalChatKey String  @map("external_chat_key")
  title           String?
  // Compacted summary of history older than the sliding window.
  summary          String    @default("") @db.Text
  summarizedUpToAt DateTime? @map("summarized_up_to_at")
  lastMessageAt    DateTime  @default(now()) @map("last_message_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  bot      ChatBot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([botId, externalChatKey])
  @@index([botId, lastMessageAt(sort: Desc)])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String          @id @default(uuid())
  sessionId String          @map("session_id")
  role      ChatMessageRole
  content   String          @db.Text
  // Compact record of tool activity behind an assistant reply (UI/debugging).
  toolCalls Json? @map("tool_calls") @db.JsonB
  // AgentRun that produced this reply — links to token usage and decisions.
  agentRunId String? @map("agent_run_id")
  // Platform message id, deduped on connector redelivery.
  externalMessageId String?  @map("external_message_id")
  externalUserId    String?  @map("external_user_id")
  createdAt         DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}
