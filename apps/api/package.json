    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "form-data": "^4.0.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "node-fetch": "^3.3.2",
