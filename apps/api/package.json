  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "e2e": "bun run test:e2e",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:remote": "TEST_API_URL=${TEST_API_URL:-http://localhost:8000/} jest --config ./test/jest-e2e.remote.json",
    "test:integration": "jest --config ./test/jest-e2e.json test/source.e2e-spec.ts",
    "test:integration:run": "bash ./scripts/run-integration-tests.sh",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:deploy": "bunx prisma migrate deploy",
    "prisma:studio": "bunx prisma studio",
    "openapi:generate": "bun run scripts/generate-openapi-spec.ts",
    "test:i18n": "jest src/i18n/i18n-keys.spec.ts --no-coverage"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.11",
