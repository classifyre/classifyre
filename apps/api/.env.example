# Database
DATABASE_URL="postgresql://user:password@localhost:5432/classifyre"

# API
PORT=8000
API_URL=http://localhost:8000

# CLI Runner
ENVIRONMENT=development
CLI_PATH=../cli
TEMP_DIR=/tmp

# S3-compatible object storage
# Runner logs and sandbox files are stored in S3. When these are unset the API
# falls back to the local filesystem (useful for quick local testing without S3).
#
# Backblaze B2 example:
# S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# S3_REGION=us-west-002
# S3_FORCE_PATH_STYLE=false
#
# AWS S3 example (omit S3_ENDPOINT — SDK resolves it from region):
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false
#
# MinIO / local SeaweedFS example:
# S3_ENDPOINT=http://localhost:8333
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
# Bucket for runner logs (key prefix: runner-logs/)
S3_BUCKET=classifyre-logs
S3_LOG_PREFIX=runner-logs/
# Bucket for sandbox uploaded files (key prefix: sandbox-files/)
# Can share the same bucket as S3_BUCKET — different object key prefixes prevent collisions.
S3_SANDBOX_BUCKET=classifyre-sandbox

# Masked source config encryption (recommended: a random 32-byte key, base64 encoded)
# Example generation: openssl rand -base64 32
CLASSIFYRE_MASKED_CONFIG_KEY=
# Optional passphrase-based fallback (only if key is not set)
# CLASSIFYRE_MASKED_CONFIG_PASSPHRASE=
# CLASSIFYRE_MASKED_CONFIG_SALT=

# For Docker mode
# ENVIRONMENT=docker
# CLI_PATH=/app/cli

# For Kubernetes mode
# ENVIRONMENT=kubernetes
# CLI_JOB_IMAGE=classifyre/cli:latest
# CLI_NAMESPACE=classifyre
