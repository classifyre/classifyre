# PostHog analytics (optional). The docs site is a static export, so these are
# baked in at build time. Leave the token empty to disable analytics entirely.
#
# When deployed inside the Helm chart these are injected for the web app only;
# the docs/blog static sites are deployed separately, so set them here.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# Ingest host the browser SDK talks to. Use the regional PostHog host
# (https://eu.i.posthog.com for EU Cloud, https://us.i.posthog.com for US).
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# UI host for toolbar links etc. (https://eu.posthog.com for EU Cloud).
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
