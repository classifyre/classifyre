{
  "name": "classifyre-desktop",
  "productName": "Classifyre",
  "version": "0.4.64",
  "private": true,
  "description": "Classifyre Desktop — Electron app with embedded PostgreSQL",
  "main": ".vite/build/index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "electron-forge start",
    "build": "electron-forge package",
    "make": "electron-forge make",
    "test": "npx tsx test/namespace-lifecycle.test.ts",
    "test:e2e": "npx playwright test --config test/playwright.config.ts",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "embedded-postgres": "18.4.0-beta.17",
    "get-port": "^7.1.0",
    "tree-kill": "^1.2.2"
  },
  "optionalDependencies": {
    "@embedded-postgres/linux-arm64": "18.4.0-beta.17",
    "@embedded-postgres/linux-x64": "18.4.0-beta.17"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron/osx-sign": "^2.5.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-vite": "^7.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^26.1.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "electron": "^43.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "playwright": "^1.59.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.4"
  }
}
