<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the bundled CPython interpreter (resources/python) and its
  virtualenv (resources/venv). Scoped to the Python binaries via
  forge.config.ts and scripts/resign-macos.mjs; the Electron app and helpers
  keep osx-sign's stricter defaults. disable-library-validation lets the
  hardened-runtime interpreter dlopen runtime-installed connector extensions
  that are ad-hoc signed under a different Team ID (e.g. psycopg2), which
  library validation would otherwise refuse to load.

  IMPORTANT: this file must contain NO angle-bracket tokens inside comments and
  no markup-like text. codesign's entitlements parser (AMFIUnserializeXML) is
  not a full XML parser and fails with "syntax error" on such content, even
  though plutil considers the file valid. The previous comment included a
  literal name placeholder in angle brackets and broke signing of the venv.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
  </dict>
</plist>
