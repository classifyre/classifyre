              "description": "Potential legal risk wording"
            }
          ],
          "zero_shot_model": "MoritzLaurer/mDeBERTa-v3-base-mnli-xnli",
          "hypothesis_template": "This text contains {}.",
          "training_examples": [],
          "min_examples_per_label": 8,
