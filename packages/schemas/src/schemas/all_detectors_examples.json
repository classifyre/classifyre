        }
      }
    },
    {
      "name": "DACH Regulatory Entity Extractor",
      "description": "Extract custom regulatory entities using GLiNER labels.",
      "config": {
        "custom_detector_key": "cust_dach_entity_extractor",
        "name": "DACH Regulatory Entity Extractor",
        "method": "ENTITY",
        "languages": [
          "de",
          "en"
        ],
        "confidence_threshold": 0.72,
        "entity": {
          "entity_labels": [
            "handelsregisternummer",
            "w-idnr",
            "steuernummer",
            "finma_identifier"
          ],
          "model": "fastino/gliner2-base-v1"
        }
      }
    },
    {
      "name": "German Compound Ruleset",
      "description": "Regex and keyword rules tailored for German compliance phrases.",
      "config": {
        "custom_detector_key": "cust_de_compound_ruleset",
        "name": "German Compound Ruleset",
        "method": "RULESET",
        "languages": [
          "de"
        ],
        "confidence_threshold": 0.75,
        "ruleset": {
          "regex_rules": [
            {
              "id": "de_handelsregister",
              "name": "Handelsregister Number",
              "pattern": "\\b(?:HRB|HRA)\\s?\\d{2,8}\\b",
              "flags": "i",
              "severity": "medium"
            }
          ],
          "keyword_rules": [
            {
              "id": "de_data_protection",
              "name": "Data Protection Officer",
              "keywords": [
                "datenschutzbeauftragter",
                "datenschutzfolgeabschatzung"
              ],
              "case_sensitive": false,
              "severity": "low"
            }
          ]
        }
      }
    },
    {
      "name": "NetzDG Illegal Content Signals",
      "description": "Classifier labels for policy review queues aligned to NetzDG categories.",
      "config": {
        "custom_detector_key": "cust_netzdg_content_signals",
        "name": "NetzDG Illegal Content Signals",
        "method": "CLASSIFIER",
        "languages": [
          "de"
        ],
        "classifier": {
          "labels": [
            {
              "id": "hate_speech",
              "name": "Hate Speech"
            },
            {
              "id": "threat_of_violence",
              "name": "Threat of Violence"
            },
            {
              "id": "incitement",
              "name": "Incitement"
            }
          ],
          "min_examples_per_label": 8,
          "training_examples": [
            {
              "text": "Wir werden euch morgen angreifen.",
              "label": "threat_of_violence",
              "accepted": true
            }
          ],
          "hypothesis_template": "This text contains {}."
        }
      }
    },
    {
      "name": "German Invoice PII Ruleset",
      "description": "Ruleset for invoice and procurement text (IBAN, VAT, tax IDs).",
      "config": {
        "custom_detector_key": "cust_invoice_pii_ruleset",
        "name": "German Invoice PII Ruleset",
        "method": "RULESET",
        "languages": [
          "de",
          "en"
        ],
        "ruleset": {
          "regex_rules": [
            {
              "id": "iban_de",
              "name": "German IBAN",
              "pattern": "\\bDE\\d{20}\\b",
              "flags": "i",
              "severity": "high"
            },
            {
              "id": "ust_id",
              "name": "EU VAT ID",
              "pattern": "\\bDE\\d{9}\\b",
              "flags": "i",
              "severity": "medium"
            }
          ],
          "keyword_rules": [
