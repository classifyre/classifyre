{
  "name": "classifyre",
  "version": "0.4.1-SNAPSHOT",
  "private": true,
  "scripts": {
    "build": "turbo build --filter=!@workspace/devops",
    "docs:generate": "node scripts/extract-helm-values.mjs",
    "docs:check-generated": "node scripts/extract-helm-values.mjs --check",
    "docs:build": "bun run --cwd apps/docs build",
    "docs:sync": "node scripts/sync-docs-to-web.mjs",
    "docs:bundle": "bun run docs:build && bun run docs:sync",
    "dev": "turbo dev --filter=@classifyre/api --filter=@classifyre/web --filter=@classifyre/docs --filter=@classifyre/blog",
    "docs:dev": "turbo dev --filter=@classifyre/docs",
    "lint": "turbo lint --filter=!@workspace/devops",
    "typecheck": "turbo check-types --filter=!@workspace/devops",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "codegen": "turbo codegen",
    "api:migrate": "cd apps/api && bun --env-file=.env run prisma:deploy && bun run prisma:generate",
    "test": "turbo test --filter=!@workspace/devops",
    "test:e2e": "turbo test:e2e",
    "test:e2e:remote": "cd apps/api && bun run test:e2e:remote && cd ../cli && bun run test:e2e",
    "test:integration": "cd apps/api && bun run test:integration",
    "api:test:e2e": "cd apps/api && bun run test:e2e",
    "api:test:e2e:sandbox": "cd apps/api && bun run test:e2e -- --testPathPattern=sandbox",
    "ops:build": "turbo build --filter=@workspace/devops",
    "ops:lint": "turbo lint --filter=@workspace/devops",
    "ops:test": "turbo test --filter=@workspace/devops",
    "ops:docker:build": "turbo run docker:build --filter=@workspace/devops",
    "ops:docker:build:multiarch": "turbo run docker:build:multiarch --filter=@workspace/devops",
    "ops:docker:smoke": "bash ./scripts/docker-smoke-allinone.sh",
    "ops:helm:lint": "turbo run helm:lint --filter=@workspace/devops",
    "ops:helm:docs": "turbo run helm:docs --filter=@workspace/devops",
    "ops:helm:docs:check": "turbo run helm:docs:check --filter=@workspace/devops",
    "ops:helm:snapshot": "turbo run helm:snpshot --filter=@workspace/devops",
    "ops:helm:snapshot:check": "turbo run helm:snpshot:check --filter=@workspace/devops",
    "ops:helm:test": "turbo run helm:test --filter=@workspace/devops",
    "test:all": "bun run test && bun run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.33.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next": "16.1.7",
    "react-medium-image-zoom": "5.4.1",
    "@playwright/test": "1.59.1"
  }
}
